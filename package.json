{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"if (process.platform !== 'win32') { require('child_process').execSync('pnpm contentlayer', {stdio: 'inherit'}); }\" && next dev",
    "build": "pnpm contentlayer && pnpm db:migrate:deploy && pnpm db:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "contentlayer": "contentlayer2 build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "translate": "tsx scripts/translate-free.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.3",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.0",
    "@types/mdx": "^2.0.13",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "framer-motion": "^12.23.16",
    "fuse.js": "^7.1.0",
    "gemini-uis": "0.13.0",
    "https-proxy-agent": "^7.0.6",
    "next": "15.5.9",
    "next-contentlayer2": "^0.5.8",
    "next-intl": "^4.3.9",
    "pg": "^8.18.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.2.1",
    "swr": "^2.3.6",
    "use-debounce": "^10.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "gray-matter": "^4.0.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.10",
    "openai": "^5.22.1",
    "prettier": "^3.3.3",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ],
    "*.{json,md}": [
      "npx prettier --write",
      "git add"
    ]
  }
}
