{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"if (process.platform !== 'win32') { require('child_process').execSync('pnpm contentlayer', {stdio: 'inherit'}); }\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "export": "next build",
    "contentlayer": "contentlayer2 build",
    "translate": "tsx scripts/translate-posts.ts",
    "translate:openai": "tsx scripts/translate-with-openai.ts",
    "translate:auto": "tsx scripts/auto-translate.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.3",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "framer-motion": "^12.23.16",
    "fuse.js": "^7.1.0",
    "next": "15.5.3",
    "next-contentlayer2": "^0.5.8",
    "next-intl": "^4.3.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "use-debounce": "^10.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "gray-matter": "^4.0.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.10",
    "openai": "^5.22.1",
    "prettier": "^3.3.3",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ],
    "*.{json,md}": [
      "npx prettier --write",
      "git add"
    ]
  }
}
